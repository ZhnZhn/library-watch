{
  "name": "library-watch",
  "version": "0.12.0",
  "description": "Web app Library Watch gives the ability to view information about GitHub's repositories, NPM's packages, StackOverflows's questions.",
  "main": "index.js",
  "scripts": {
    "dev": "webpack serve --config webpack.dev.js",
    "dev:rspack": "rspack serve --config rspack.dev.js",
    "transpile": "babel ./src --out-dir ./js --source-maps --ignore ./**/__tests__",
    "transpile:all": "babel ./src --out-dir ./js --source-maps",
    "lint:one": "eslint -c eslint.config.js",
    "lint:biome": "npx @biomejs/biome lint ./src --colors=off --skip=noAssignInExpressions --skip=noCommaOperator --skip=noExportsInTest --skip=noStaticElementInteractions --skip=useKeyWithClickEvents",
    "lint:only": "npx @biomejs/biome lint ./src --only=noStaticElementInteractions --colors=off",
    "css:min": "node min-css.js",
    "build:prod": "webpack --color --progress --config webpack.prod.js",
    "stats": "npm run stats:json && npm run stats:report",
    "stats:json": "webpack --config webpack.test.js --profile --json > stats.json",
    "stats:report": "webpack-bundle-analyzer stats.json --no-open --mode static",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "author": "Yevhenii Molodyi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZhnZhn/library-watch.git"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "chart.js": "^4.5.1",
    "papaparse": "^5.5.3",
    "raven-js": "^3.27.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@biomejs/biome": "^2.4.16",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@rspack/cli": "^2.0.4",
    "@rspack/core": "^2.0.4",
    "@rspack/dev-server": "^2.0.1",
    "@rspack/plugin-react-refresh": "^2.0.0",
    "@swc/helpers": "^0.5.23",
    "babel-jest": "^30.4.1",
    "babel-loader": "^10.1.1",
    "clean-css": "^5.3.3",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "terser-webpack-plugin": "^5.6.1",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.4"
  },
  "overrides": {
    "glob": "~13.0.6",
    "uuid": "~14.0.0"
  },
  "jest": {
    "roots": [
      "<rootDir>/js/components/charts",
      "<rootDir>/js/flux/",
      "<rootDir>/js/utils/"
    ],
    "transformIgnorePatterns": [
      "<rootDir>/js/components/charts",
      "<rootDir>/js/flux/",
      "<rootDir>/js/utils/"
    ]
  }
}
